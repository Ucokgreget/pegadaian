generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id              Int               @id @default(autoincrement())
  name            String?
  email           String            @unique
  password        String
  role            Role              @default(USER)
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  accessToken   String?  @db.Text
  refreshToken  String?  @db.Text
  rememberToken String?  @db.Text

  // Relations
  devices         Device[]
  chatbotSettings ChatbotSettings?
  conversations   Conversation[]
  customers       Customer[]
  contactLists    ContactList[]
  products        Product[]
  subscriptions   Subscription[]
  orders          Order[]
  invoices        Invoice[]         // FIX: tambah relasi balik dari Invoice
  payments        Payment[]         // FIX: tambah relasi balik dari Payment

  @@map("users")
}

model Device {
  id              Int              @id @default(autoincrement())
  userId          Int
  deviceName      String?
  phone           String
  status          String           @default("DISCONNECTED")
  packageName     String           @default("FREE")
  expiredAt       DateTime?
  isActive        Boolean          @default(true)
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  user            User             @relation(fields: [userId], references: [id])
  chatbotSettings ChatbotSettings? // FIX: relasi balik sudah ada di ChatbotSettings

  @@map("devices")
}

model ChatbotSettings {
  id             Int      @id @default(autoincrement())
  deviceId       Int      @unique  // FIX: tambah @unique untuk one-to-one relation
  userId         Int      @unique  // FIX: pisahkan foreign key untuk User
  isActive       Boolean  @default(false)
  welcomeMessage String   @default("Halo! Terima kasih telah menghubungi kami. Ada yang bisa saya bantu?")
  device         String?
  aiPrompt       String?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  deviceRelation Device   @relation(fields: [deviceId], references: [id]) // FIX: relasi ke Device (bukan User)
  user           User     @relation(fields: [userId], references: [id])   // FIX: relasi ke User dengan FK terpisah

  @@map("chatbot_settings")
}

model Conversation {
  id         Int      @id @default(autoincrement())
  userId     Int
  sender     String
  message    String
  response   String?
  isIncoming Boolean  @default(true) @map("is_incoming")
  createdAt  DateTime @default(now()) @map("created_at")

  user       User     @relation(fields: [userId], references: [id])

  @@map("conversations")
}

model Customer {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  phone     String?
  address   String?
  notes     String?
  userId    Int
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user      User     @relation(fields: [userId], references: [id])

  @@map("customers")
}

model ContactList {
  id        Int      @id @default(autoincrement())
  userId    Int
  name      String?
  phone     String
  category  String?
  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation(fields: [userId], references: [id])

  @@map("contact_lists")
}

model Product {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  price       Int
  stock       Int      @default(0)
  imageUrl    String?
  userId      Int
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user        User     @relation(fields: [userId], references: [id])

  @@map("products")
}

model Order {
  id              Int         @id @default(autoincrement())
  userId          Int
  packageId       Int
  addonId         Int?
  orderCode       String      @unique
  type            String
  reference       String?
  amount          Int
  paidAt          DateTime?
  status          OrderStatus @default(PENDING)
  tripayReference String?
  tripayPayload   Json?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  user       User        @relation(fields: [userId], references: [id])
  package    Package     @relation(fields: [packageId], references: [id])
  orderItems OrderItem[]
  invoice    Invoice?
  addon      Addon? @relation(fields: [addonId], references: [id])

  @@map("orders")
}

model OrderItem {
  id           Int     @id @default(autoincrement())
  orderId      Int
  packageId    Int     // FIX: tambah packageId FK
  itemType     String
  itemName     String
  reference    String?
  qty          Int     @default(1)
  price        Int
  total        Int
  durationDays Int

  order   Order   @relation(fields: [orderId], references: [id])
  package Package @relation(fields: [packageId], references: [id]) // FIX: tambah relasi ke Package

  @@map("order_items")
}

model Package {
  id            Int      @id @default(autoincrement())
  key           String   @unique
  name          String
  price         Int
  priceLabel    String?
  billingPeriod String   @default("monthly")
  isPopular     Boolean  @default(false)
  isCustomPrice Boolean  @default(false)
  isActive      Boolean  @default(true)
  sortOrder     Int      @default(0)
  durationDays  Int      @default(30)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  subscriptions   Subscription[]
  orders          Order[]          // FIX: tambah relasi balik dari Order
  orderItems      OrderItem[]      // FIX: relasi balik dari OrderItem (sudah ada, perlu relasi di OrderItem)
  packageFeatures PackageFeature[] // FIX: tambah relasi balik dari PackageFeature
  invoiceItems    InvoiceItem[]    // FIX: tambah relasi balik dari InvoiceItem
  // REMOVED: packages Package[] — self-relation tidak valid tanpa konfigurasi yang benar

  @@map("packages")
}

model PackageFeature {
  id            Int      @id @default(autoincrement())
  packageId     Int
  featureText   String
  isHighlighted Boolean  @default(false)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  package Package @relation(fields: [packageId], references: [id]) // FIX: relasi balik sudah ditambah di Package

  @@map("package_features")
}

model Subscription {
  id               Int                @id @default(autoincrement())
  userId           Int
  packageId        Int
  invoiceId        Int?               @unique // FIX: tambah @unique untuk one-to-one dengan Invoice
  startedAt        DateTime
  expiredAt        DateTime
  cancelledAt      DateTime?
  gracePeriodUntil DateTime?
  status           SubscriptionStatus @default(ACTIVE)
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")

  user    User     @relation(fields: [userId], references: [id])
  package Package  @relation(fields: [packageId], references: [id])
  invoice Invoice? @relation(fields: [invoiceId], references: [id]) // FIX: relasi balik ditambah di Invoice

  @@map("subscriptions")
}

model SubscriptionFeature {
  id          Int      @id @default(autoincrement())
  featureKey  String   @unique
  featureName String
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("subscription_features")
}

model Invoice {
  id            Int           @id @default(autoincrement())
  userId        Int
  invoiceNumber String        @unique
  orderId       Int           @unique // FIX: tambah @unique untuk one-to-one dengan Order
  subtotal      Float
  tax           Float         @default(0.00)
  total         Float
  status        InvoiceStatus @default(UNPAID)
  issuedAt      DateTime
  dueDate       DateTime?
  paidAt        DateTime?
  meta          Json?
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  user         User          @relation(fields: [userId], references: [id])   // FIX: relasi balik ditambah di User
  order        Order         @relation(fields: [orderId], references: [id])
  subscription Subscription?  // FIX: relasi balik dari Subscription
  payments     Payment[]
  invoiceItems InvoiceItem[]

  @@map("invoices")
}

model InvoiceItem {
  id           Int      @id @default(autoincrement())
  invoiceId    Int
  packageId    Int
  description  String
  qty          Int      @default(1)
  price        Float
  total        Float
  durationDays Int
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  invoice Invoice @relation(fields: [invoiceId], references: [id])
  package Package @relation(fields: [packageId], references: [id]) // FIX: relasi balik ditambah di Package

  @@map("invoice_items")
}

model Payment {
  id              Int           @id @default(autoincrement())
  userId          Int
  invoiceId       Int
  tripayReference String        @unique
  merchantRef     String
  paymentMethod   String
  amount          Float
  status          PaymentStatus @default(PENDING)
  payload         Json?
  paidAt          DateTime?
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  user    User    @relation(fields: [userId], references: [id])    // FIX: relasi balik ditambah di User
  invoice Invoice @relation(fields: [invoiceId], references: [id])

  @@map("payments")
}

model PromoCode {
  id          Int       @id @default(autoincrement()) @db.UnsignedInt
  code        String    @unique
  type        PromoType
  value       Int
  maxDiscount Int?      @map("max_discount")
  quota       Int?
  used        Int       @default(0)
  startAt     DateTime  @map("start_at") @db.Date
  endAt       DateTime  @map("end_at") @db.Date
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime? @default(now()) @map("created_at")
  updatedAt   DateTime? @updatedAt @map("updated_at")

  @@map("promo_codes")
}

model Addon {
  id          Int      @id @default(autoincrement())
  key         String   @unique
  name        String
  description String?
  price       Int
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  orderItems  OrderItem[]

  @@map("addons")
}

enum PromoType {
  fixed
  percent
}

enum OrderStatus {
  PENDING
  PAID
  FAILED
  EXPIRED
}

enum InvoiceStatus {
  UNPAID
  PAID
  CANCELLED
  REFUNDED
}

enum Role {
  ADMIN
  USER
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  EXPIRED
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}
